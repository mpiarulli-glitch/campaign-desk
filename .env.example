ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_APP_URL=http://localhost:3040
# AI provider (pick one). GROQ is strongly recommended — much cheaper than xAI/OpenAI for this use case.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# Optional fallbacks
# XAI_API_KEY=your-xai-api-key
# XAI_MODEL=grok-3
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5.6-luna   # or gpt-5.4-mini / gpt-5.6-terra for more power
