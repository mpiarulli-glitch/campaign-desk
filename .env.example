ADMIN_PASSWORD=change-me-to-a-strong-password
SESSION_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_APP_URL=http://localhost:3040
# AI provider (pick one). GROQ is strongly recommended — much cheaper than xAI/OpenAI for this use case.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile

# Optional fallbacks
# XAI_API_KEY=your-xai-api-key
# XAI_MODEL=grok-3
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5.6-luna   # or gpt-5.4-mini / gpt-5.6-terra for more power

# Basecamp Campfire notifications (optional).
# Posts a message to a Basecamp Campfire when a client leaves feedback or a
# campaign is deleted. Create a chatbot in the Campfire, then paste the
# generated "post messages to this URL" endpoint here. Leave blank to disable.
# BASECAMP_CAMPFIRE_URL=https://3.basecampapi.com/5338018/integrations/XXXX/buckets/31712238/chats/5872466951/lines.json

# Production scheduling reminder emails (Resend).
# When set, the /api/cron/reminders job emails clients their scheduling link
# starting 3 weeks before their window opens, once a day until they book.
# Create a Resend account, verify a sending domain, and fill these in.
# EMAIL_FROM must be a verified sender on that domain. Leave blank to disable
# (the job still runs and reports, it just won't send).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Marketing Empire Group <scheduling@yourdomain.com>
# EMAIL_REPLY_TO=you@yourdomain.com

# Shared secret guarding the reminder cron endpoint. Your scheduler sends it as
# "Authorization: Bearer <CRON_SECRET>" (or ?secret=). Use a long random string.
# CRON_SECRET=change-me-to-a-long-random-string
